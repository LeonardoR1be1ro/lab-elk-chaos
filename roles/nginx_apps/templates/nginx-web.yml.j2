apiVersion: v1
kind: ConfigMap
metadata:
  name: nginx-web-conf
  namespace: {{ ns_apps }}
data:
  default.conf: |
    server {
        listen 80;
        server_name _;
        root /usr/share/nginx/html;

        location / {
            index index.html;
        }

        # Endpoint de saúde
        location = /ok {
            default_type text/plain;
            return 200 "nginx-web: OK\n";
        }

        # Endpoints usados pelos cenários de chaos
        location = /erro/404 {
            return 404;
        }
        location = /erro/500 {
            return 500;
        }
        location = /erro/503 {
            return 503;
        }

        # Resposta lenta: ~40KB limitados a 2KB/s (~20s de download)
        location = /lento {
            limit_rate 2k;
            try_files /slow.html =404;
        }

        # stub_status para o modulo nginx do Metricbeat (via hints)
        location = /nginx_status {
            stub_status on;
            access_log off;
        }
    }
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx-web
  namespace: {{ ns_apps }}
  labels:
    app: nginx-web
spec:
  replicas: 2
  selector:
    matchLabels:
      app: nginx-web
  template:
    metadata:
      labels:
        app: nginx-web
      annotations:
        # Hints do Metricbeat: coleta do stub_status automaticamente
        co.elastic.metrics/module: nginx
        co.elastic.metrics/metricsets: stubstatus
        co.elastic.metrics/hosts: "${data.host}:80"
        co.elastic.metrics/server_status_path: /nginx_status
        co.elastic.metrics/period: 10s
    spec:
      containers:
        - name: nginx
          image: nginx:1.27
          ports:
            - containerPort: 80
              name: http
          resources:
            requests:
              memory: 64Mi
              cpu: 50m
            limits:
              memory: 128Mi
          readinessProbe:
            httpGet:
              path: /ok
              port: 80
            initialDelaySeconds: 3
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /ok
              port: 80
            initialDelaySeconds: 5
            periodSeconds: 10
          volumeMounts:
            - name: conf
              mountPath: /etc/nginx/conf.d
            - name: html
              mountPath: /usr/share/nginx/html
      volumes:
        - name: conf
          configMap:
            name: nginx-web-conf
        - name: html
          configMap:
            name: nginx-web-html
---
apiVersion: v1
kind: Service
metadata:
  name: nginx-web
  namespace: {{ ns_apps }}
  labels:
    app: nginx-web
spec:
  type: NodePort
  selector:
    app: nginx-web
  ports:
    - name: http
      port: 80
      targetPort: 80
      nodePort: {{ nginx_web_nodeport }}

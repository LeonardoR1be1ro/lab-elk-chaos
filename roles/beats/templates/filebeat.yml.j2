apiVersion: beat.k8s.elastic.co/v1beta1
kind: Beat
metadata:
  name: filebeat
  namespace: {{ ns_elastic }}
spec:
  type: filebeat
  version: {{ stack_version }}
  config:
    filebeat.autodiscover:
      providers:
        - type: kubernetes
          node: ${NODE_NAME}
          # Não usamos "hints" aqui de propósito. O ECK injeta annotations
          # de módulo (co.elastic.logs/module: kibana, elasticsearch, etc.)
          # nos próprios pods do Elastic Stack, e o Filebeat gera MAIS DE UM
          # fileset (ex.: audit + log) para o mesmo container. Como o ID do
          # filestream era derivado só do container ID, os dois filesets
          # colidiam em "filestream input ID ... is duplicated: input will
          # NOT start" — e isso derrubava o LOTE INTEIRO de reload do
          # autodiscover, bloqueando também a descoberta de pods novos do
          # nginx-web/nginx-chaos no mesmo ciclo. Um "template" com condição
          # explícita evita esse acoplamento por completo: só os pods do
          # nginx são considerados, o resto do cluster nem é avaliado.
          templates:
            - condition:
                or:
                  - equals:
                      kubernetes.labels.app: "nginx-web"
                  - equals:
                      kubernetes.labels.app: "nginx-chaos"
              config:
                - type: filestream
                  # O input "container" (usado por hints.default_config em
                  # versões antigas) foi descontinuado; o substituto oficial
                  # é "filestream" + parser "container".
                  id: "nginx-container-logs-${data.kubernetes.container.id}"
                  paths:
                    - /var/log/containers/*-${data.kubernetes.container.id}.log
                  prospector.scanner.symlinks: true
                  close.on_state_change.removed: false
                  parsers:
                    # "container: ~" (valor nulo em YAML) colapsava para
                    # "parsers: [null]" ao passar pelo campo `config` do
                    # Beat CR do ECK, e o Filebeat rejeitava com
                    # "no such parser accessing config". Um valor concreto
                    # (mesmo que seja só o default explícito) evita o colapso.
                    - container:
                        stream: all
    processors:
      - add_host_metadata: {}
    # Saída para o Logstash (pipeline: Filebeat -> Logstash -> Elasticsearch)
    output.logstash:
      hosts:
        - "logstash-ls-beats.{{ ns_elastic }}.svc:5044"
  daemonSet:
    podTemplate:
      spec:
        serviceAccountName: beats
        automountServiceAccountToken: true
        terminationGracePeriodSeconds: 30
        dnsPolicy: ClusterFirstWithHostNet
        containers:
          - name: filebeat
            securityContext:
              runAsUser: 0
            resources:
              requests:
                memory: 200Mi
                cpu: 100m
              limits:
                memory: 300Mi
            env:
              - name: NODE_NAME
                valueFrom:
                  fieldRef:
                    fieldPath: spec.nodeName
            volumeMounts:
              - name: varlogcontainers
                mountPath: /var/log/containers
              - name: varlogpods
                mountPath: /var/log/pods
              - name: varlibcontainers
                mountPath: /var/lib/rancher/k3s/agent/containerd
        volumes:
          - name: varlogcontainers
            hostPath:
              path: /var/log/containers
          - name: varlogpods
            hostPath:
              path: /var/log/pods
          - name: varlibcontainers
            hostPath:
              path: /var/lib/rancher/k3s/agent/containerd

apiVersion: beat.k8s.elastic.co/v1beta1
kind: Beat
metadata:
  name: filebeat
  namespace: {{ ns_elastic }}
spec:
  type: filebeat
  version: {{ stack_version }}
  config:
    filebeat.autodiscover:
      providers:
        - type: kubernetes
          node: ${NODE_NAME}
          hints.enabled: true
          hints.default_config:
            # O input "container" foi descontinuado (deprecado desde o
            # Filebeat 7.16) e passou a falhar sem iniciar o harvester
            # ("won't start runner") no autodiscover a partir da série
            # 8.12+/9.x. O substituto oficial é "filestream" com o
            # parser "container", que entende o mesmo formato de log
            # de containerd/CRI-O e do runtime Docker.
            type: filestream
            id: "kubernetes-container-logs-${data.kubernetes.container.id}"
            paths:
              - /var/log/containers/*-${data.kubernetes.container.id}.log
            prospector.scanner.symlinks: true
            close.on_state_change.removed: false
            parsers:
              - container: ~
    processors:
      - add_host_metadata: {}
    # Saída para o Logstash (pipeline: Filebeat -> Logstash -> Elasticsearch)
    output.logstash:
      hosts:
        - "logstash-ls-beats.{{ ns_elastic }}.svc:5044"
  daemonSet:
    podTemplate:
      spec:
        serviceAccountName: beats
        automountServiceAccountToken: true
        terminationGracePeriodSeconds: 30
        dnsPolicy: ClusterFirstWithHostNet
        containers:
          - name: filebeat
            securityContext:
              runAsUser: 0
            resources:
              requests:
                memory: 200Mi
                cpu: 100m
              limits:
                memory: 300Mi
            env:
              - name: NODE_NAME
                valueFrom:
                  fieldRef:
                    fieldPath: spec.nodeName
            volumeMounts:
              - name: varlogcontainers
                mountPath: /var/log/containers
              - name: varlogpods
                mountPath: /var/log/pods
              - name: varlibcontainers
                mountPath: /var/lib/rancher/k3s/agent/containerd
        volumes:
          - name: varlogcontainers
            hostPath:
              path: /var/log/containers
          - name: varlogpods
            hostPath:
              path: /var/log/pods
          - name: varlibcontainers
            hostPath:
              path: /var/lib/rancher/k3s/agent/containerd

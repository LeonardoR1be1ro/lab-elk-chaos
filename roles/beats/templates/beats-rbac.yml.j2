apiVersion: v1
kind: ServiceAccount
metadata:
  name: beats
  namespace: {{ ns_elastic }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: beats
rules:
  - apiGroups: [""]
    resources:
      - namespaces
      - pods
      - nodes
      - events
      - services
      - configmaps
    verbs: ["get", "list", "watch"]
  - apiGroups: [""]
    resources:
      - nodes/stats
      - nodes/metrics
    verbs: ["get"]
  - apiGroups: ["apps"]
    resources:
      - replicasets
      - deployments
      - daemonsets
      - statefulsets
    verbs: ["get", "list", "watch"]
  - apiGroups: ["batch"]
    resources:
      - jobs
      - cronjobs
    verbs: ["get", "list", "watch"]
  - nonResourceURLs: ["/metrics"]
    verbs: ["get"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: beats
subjects:
  - kind: ServiceAccount
    name: beats
    namespace: {{ ns_elastic }}
roleRef:
  kind: ClusterRole
  name: beats
  apiGroup: rbac.authorization.k8s.io
